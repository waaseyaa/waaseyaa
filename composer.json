{
    "name": "waaseyaa/waaseyaa",
    "description": "Waaseyaa CMS project skeleton",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "waaseyaa/foundation": "^0.1",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/entity-storage": "^0.1",
        "waaseyaa/access": "^0.1",
        "waaseyaa/user": "^0.1",
        "waaseyaa/node": "^0.1",
        "waaseyaa/taxonomy": "^0.1",
        "waaseyaa/media": "^0.1",
        "waaseyaa/path": "^0.1",
        "waaseyaa/menu": "^0.1",
        "waaseyaa/workflows": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/cli": "^0.1",
        "waaseyaa/database-legacy": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/field": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
